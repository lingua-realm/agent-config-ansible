# Codex CLI 配置文件
# 由 Ansible 模板渲染生成，请勿手动修改
# 模板来源：roles/agent_codex/templates/config.toml.j2

{% macro render_scalar(value) -%}
{{- value | to_json -}}
{%- endmacro %}

{% macro render_key(key) -%}
{%- if key is string and (key is match('^[A-Za-z0-9_-]+$')) -%}
{{- key -}}
{%- else -%}
{{- key | to_json -}}
{%- endif -%}
{%- endmacro %}

{% macro render_path(path) -%}
{%- for segment in path -%}
{%- if not loop.first %}.{% endif -%}{{ render_key(segment) }}
{%- endfor -%}
{%- endmacro %}

{% macro render_table(path, table) -%}
{% for item in table | dictsort %}
{% set key = item.0 %}
{% set value = item.1 %}
{% if value is not none and value is not mapping and (value is not string or value | length > 0) %}
{{ render_key(key) }} = {{ render_scalar(value) }}
{% endif %}
{% endfor %}
{% for item in table | dictsort %}
{% set key = item.0 %}
{% set value = item.1 %}
{% if value is mapping and value | length > 0 %}

[{{ render_path(path + [key]) }}]
{{ render_table(path + [key], value) }}
{% endif %}
{% endfor %}
{%- endmacro %}

{{ render_table([], agent_codex_config_normalized) }}
