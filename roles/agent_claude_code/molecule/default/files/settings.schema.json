{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "env",
    "model",
    "alwaysThinkingEnabled",
    "outputStyle",
    "permissions",
    "cleanupPeriodDays",
    "hooks",
    "statusLine",
    "enabledPlugins"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "env": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "model": {
      "type": "string"
    },
    "alwaysThinkingEnabled": {
      "type": "boolean"
    },
    "effortLevel": {
      "type": "string"
    },
    "outputStyle": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "permissions": {
      "type": "object",
      "required": ["allow", "deny"],
      "properties": {
        "defaultMode": {
          "type": "string"
        },
        "allow": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deny": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "attribution": {
      "type": "object"
    },
    "cleanupPeriodDays": {
      "type": "number"
    },
    "hooks": {
      "type": "object"
    },
    "statusLine": {
      "type": "object",
      "required": ["type", "command", "padding"],
      "properties": {
        "type": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "padding": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "enabledPlugins": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    }
  },
  "additionalProperties": true
}
